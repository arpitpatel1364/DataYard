# Copy this file to backend/.env and adjust as needed.
# CIS runs entirely on SQLite + an in-process scheduler - none of these
# are required to get started, but you should change the secrets below
# before any real deployment.

SECRET_KEY=change-me-to-a-long-random-string
REFRESH_SECRET_KEY=change-me-to-a-different-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Leave DATABASE_URL unset to use the default local SQLite file at
# backend/storage/cis.db. Override only if you want SQLite somewhere else.
# DATABASE_URL=sqlite:///./storage/cis.db

DEFAULT_SCAN_EVERY_MINUTES=30
